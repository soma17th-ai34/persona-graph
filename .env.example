OPENAI_API_KEY=your_api_key_here
UPSTAGE_API_KEY=your_upstage_api_key_here

# Optional: choose a default model. Use provider:model for multi-provider routing.
PERSONA_GRAPH_MODEL=openai:gpt-5.4-mini

# Optional: comma-separated model IDs exposed to users in the UI/API.
PERSONA_GRAPH_AVAILABLE_MODELS=openai:gpt-5.4-mini,upstage:solar-pro3

# Optional: override OpenAI-compatible provider base URLs.
# OPENAI_BASE_URL=https://api.openai.com/v1
# UPSTAGE_BASE_URL=https://api.upstage.ai/v1

# Optional: Tavily API key for higher-quality web search augmentation.
# If omitted, PersonaGraph falls back to best-effort DuckDuckGo HTML search.
# TAVILY_API_KEY=your_tavily_api_key_here
